# =========================================================
# Browser-Caching & Kompression fuer mch-singen.de
#
# WICHTIG: Diese Datei wirkt NUR auf Apache-Hosting.
# GitHub Pages (aktuelles Hosting laut CNAME) ignoriert sie und
# setzt selbst fest "Cache-Control: max-age=600" fuer alle Dateien.
# Sie liegt hier fuer einen spaeteren Umzug auf klassisches Hosting
# bzw. als Referenz-Konfiguration bereit.
# =========================================================

# --- Lange Cache-Zeiten fuer statische, versionierte Assets ---
<IfModule mod_headers.c>
  # Bilder, Fonts: 1 Jahr, immutable (Dateinamen aendern sich bei Updates)
  <FilesMatch "\.(jpg|jpeg|png|gif|webp|svg|ico|woff2|woff|ttf)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>

  # CSS/JS: 1 Jahr (bei Aenderungen Dateinamen versionieren, z. B. bundle.v2.min.css)
  <FilesMatch "\.(css|js)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>

  # PDF-Dokumente: 1 Tag (werden gelegentlich ersetzt, Dateiname bleibt gleich)
  <FilesMatch "\.pdf$">
    Header set Cache-Control "public, max-age=86400"
  </FilesMatch>

  # Daten-Dateien (Countdown-Termine, Live-Daten): immer frisch
  <FilesMatch "\.(json|txt)$">
    Header set Cache-Control "no-cache"
  </FilesMatch>

  # HTML: immer neu validieren, damit Aenderungen sofort sichtbar sind
  <FilesMatch "\.html$">
    Header set Cache-Control "no-cache"
  </FilesMatch>
</IfModule>

# --- Textbasierte Inhalte komprimieren ---
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/css text/plain text/xml
  AddOutputFilterByType DEFLATE application/javascript application/json
  AddOutputFilterByType DEFLATE image/svg+xml font/ttf
</IfModule>

# --- Korrekte MIME-Types fuer moderne Formate ---
<IfModule mod_mime.c>
  AddType image/webp .webp
  AddType font/woff2 .woff2
</IfModule>
